# 复制为 .env.local（本地）或用 `wrangler secret put`（线上）设置。

# 站点公开地址（影响分享卡 OG 图片 + TG 播报里的链接）。本地可留空。
NEXT_PUBLIC_BASE_URL=https://your-site.pages.dev

# Reown(WalletConnect) 项目 ID —— dApp 钱包连接必填。
# 在 https://dashboard.reown.com 免费注册项目拿到，并在项目里把本站域名加入 allowlist。
# 注意：NEXT_PUBLIC_ 变量在「构建时」内联进前端包，必须同时存在于构建环境与 wrangler [vars]。
# 仅做注入式（币安/OKX 内置浏览器）连接时可临时留空，但普通浏览器扫码连接需要它。
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Telegram 自动播报（用 @BotFather 建 bot 拿 token；chat id 为频道 @用户名 或数字 id）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 保护 /api/cron/broadcast 的密钥（自己随便设一串，cron 调用时带 ?key=该值）
CRON_SECRET=
